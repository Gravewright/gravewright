{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gravewright.dev/schemas/system-manifest-v1.json",
  "title": "Gravewright System Manifest v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "manifestVersion",
    "type",
    "id",
    "name",
    "version",
    "apiVersion",
    "compatibility",
    "capabilities",
    "system"
  ],
  "properties": {
    "manifestVersion": {
      "const": 1
    },
    "type": {
      "const": "system"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "apiVersion": {
      "const": "1"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string"
          }
        }
      }
    },
    "license": {
      "type": "string"
    },
    "homepage": {
      "type": "string"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum": {
          "type": "string"
        },
        "verified": {
          "type": "string"
        },
        "maximum": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "minimum"
          ]
        },
        {
          "required": [
            "maximum"
          ]
        }
      ]
    },
    "display": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "color": {
          "type": "string"
        },
        "icon": {
          "$ref": "#/$defs/packagePath"
        },
        "cover": {
          "$ref": "#/$defs/packagePath"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "actors.register",
          "items.register",
          "sheets.declarative",
          "rules.declarative",
          "content.packs",
          "tokens.mappings",
          "dice.roll",
          "chat.cards",
          "roll.toast",
          "locales",
          "assets.ui",
          "assets.styles",
          "assets.scripts",
          "combat.config",
          "combat.hooks",
          "rolls.intent"
        ]
      },
      "uniqueItems": true
    },
    "system": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "storage",
        "actorTypes"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "storage": {
          "type": "object",
          "required": [
            "model"
          ],
          "properties": {
            "model": {
              "const": "scoped-json-v1"
            }
          }
        },
        "assets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "styles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/packagePath"
              }
            },
            "scripts": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/packagePath"
              }
            }
          }
        },
        "actorTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entityType"
          }
        },
        "itemTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entityType"
          }
        },
        "contentPacks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contentPack"
          }
        },
        "locales": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/packagePath"
          }
        },
        "rules": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/packagePath"
          }
        },
        "mappings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/packagePath"
          }
        },
        "areaMarkers": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "defaults": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  },
  "$defs": {
    "packagePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*://)(?!.*(^|/)\\.\\.(/|$))(?!.*//).+[^/]$"
    },
    "entityType": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "label",
        "schema",
        "sheet"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "$ref": "#/$defs/packagePath"
        },
        "sheet": {
          "$ref": "#/$defs/packagePath"
        }
      }
    },
    "contentPack": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "label",
        "path"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "actor_pack",
            "item_pack",
            "spell_pack",
            "journal_pack",
            "table_pack",
            "condition_pack"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/packagePath"
        }
      }
    }
  }
}
