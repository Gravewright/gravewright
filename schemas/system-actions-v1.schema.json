{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gravewright.dev/schemas/system-actions-v1.json",
  "title": "Gravewright System Actions v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actions"
  ],
  "properties": {
    "actions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/action"
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "label"
      ],
      "properties": {
        "type": {
          "enum": [
            "roll",
            "patch",
            "macro"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "$ref": "#/$defs/rollIntent"
        },
        "formula": {
          "type": "string"
        },
        "visibility": {
          "enum": [
            "public",
            "gm",
            "private"
          ]
        },
        "chatCard": {
          "type": "string"
        },
        "rollToast": {
          "type": "object"
        },
        "dialog": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "intent": {
              "$ref": "#/$defs/rollIntent"
            },
            "fields": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          }
        },
        "transforms": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "patches": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "rollIntent": {
      "enum": [
        "check",
        "save",
        "attack",
        "damage",
        "initiative",
        "skill",
        "tool",
        "custom"
      ]
    }
  }
}
