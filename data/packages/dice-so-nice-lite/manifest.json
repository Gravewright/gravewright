{
  "schemaVersion": 1,
  "type": "module",
  "id": "dice-so-nice-lite",
  "name": "Dice So Nice Lite",
  "version": "0.1.0",
  "apiVersion": "1",
  "description": "Local 3D dice overlay with a user-selectable die color.",
  "authors": [
    {
      "name": "Gravewright"
    }
  ],
  "compatibility": {
    "minimum": "1.0.0-rc.1",
    "verified": "1.0.0-rc.1",
    "maximum": "1.x"
  },
  "capabilities": [
    "assets.ui",
    "assets.styles",
    "assets.scripts",
    "settings"
  ],
  "display": {
    "color": "#7c5cff"
  },
  "module": {
    "id": "dice-so-nice-lite",
    "entrypoints": {
      "game": {
        "styles": [
          "assets/dice-so-nice-lite.css"
        ],
        "scripts": [
          "assets/dice-so-nice-lite.js"
        ]
      }
    },
    "settings": [
      {
        "key": "dice.color",
        "scope": "user",
        "type": "string",
        "default": "#7c5cff",
        "label": "Die color"
      }
    ]
  }
}
