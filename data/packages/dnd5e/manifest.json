{
  "$schema": "https://raw.githubusercontent.com/Gravewright/gravewright/main/schemas/gravewright-package-v1.schema.json",
  "schemaVersion": 1,
  "sdkVersion": "1",
  "kind": "ruleset",
  "id": "dnd5e",
  "name": "Dungeons & Dragons 5e",
  "version": "0.3.0",
  "description": "Sistema 5e declarativo para Gravewright: fichas de personagem e monstro, itens, magias, talentos, raças, classes e antecedentes. Inclui packs de modelo para testar drag/drop; não inclui compêndio oficial completo.",
  "authors": [
    "Gravewright"
  ],
  "license": "No official content bundled",
  "compatibility": {
    "minimum": "1.0.0-rc.1",
    "verified": "1.0.0-rc.1",
    "maximum": "1.x"
  },
  "capabilities": [
    "actors.register",
    "items.register",
    "sheets.declarative",
    "sheets.hooks",
    "rules.declarative",
    "content.packs",
    "tokens.mappings",
    "dice.roll",
    "chat.cards",
    "rolls.intent",
    "locales",
    "assets.ui",
    "assets.styles",
    "assets.scripts",
    "combat.config",
    "combat.hooks"
  ],
  "activation": {
    "scope": "campaign",
    "mode": "exclusive"
  },
  "display": {
    "color": "#7a1f2b"
  },
  "entrypoints": {
    "game": {
      "styles": [
        "assets/dnd5e.css"
      ],
      "scripts": [
        "assets/dnd5e-sheets.js",
        "assets/combat-panel.js"
      ]
    }
  },
  "provides": {
    "storage": {
      "model": "scoped-json-v1"
    },
    "defaults": {
      "actorType": "character",
      "itemType": "weapon",
      "locale": "en"
    },
    "actorTypes": [
      {
        "id": "character",
        "labelKey": "dnd5e.ui.personagem",
        "schema": "schemas/character.schema.json",
        "sheet": "layouts/character.sheet.gw.json"
      },
      {
        "id": "monster",
        "labelKey": "dnd5e.ui.monstro",
        "schema": "schemas/monster.schema.json",
        "sheet": "layouts/monster.sheet.gw.json"
      }
    ],
    "itemTypes": [
      {
        "id": "weapon",
        "labelKey": "dnd5e.ui.arma",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/weapon.sheet.gw.json"
      },
      {
        "id": "armor",
        "labelKey": "dnd5e.ui.armadura",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/armor.sheet.gw.json"
      },
      {
        "id": "equipment",
        "labelKey": "dnd5e.ui.equipamento",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/equipment.sheet.gw.json"
      },
      {
        "id": "consumable",
        "labelKey": "dnd5e.ui.consumivel",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/consumable.sheet.gw.json"
      },
      {
        "id": "spell",
        "labelKey": "dnd5e.ui.magia",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/spell.sheet.gw.json"
      },
      {
        "id": "feat",
        "labelKey": "dnd5e.ui.talento",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/feat.sheet.gw.json"
      },
      {
        "id": "feature",
        "labelKey": "dnd5e.ui.caracteristica",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/feature.sheet.gw.json"
      },
      {
        "id": "race",
        "labelKey": "dnd5e.ui.raca",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/race.sheet.gw.json"
      },
      {
        "id": "background",
        "labelKey": "dnd5e.ui.antecedente",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/background.sheet.gw.json"
      },
      {
        "id": "class",
        "labelKey": "dnd5e.ui.classe",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/class.sheet.gw.json"
      },
      {
        "id": "effect",
        "labelKey": "dnd5e.ui.efeito",
        "schema": "schemas/item.schema.json",
        "sheet": "layouts/items/effect.sheet.gw.json"
      }
    ],
    "areaMarkers": [
      {
        "id": "dnd5e-spell-sphere",
        "labelKey": "dnd5e.ui.magia.esfera.raio",
        "shape": "circle",
        "style": {
          "stroke": "rgba(125, 211, 252, 0.96)",
          "fill": "rgba(125, 211, 252, 0.16)",
          "strokeWidth": 2
        }
      },
      {
        "id": "dnd5e-spell-cone",
        "labelKey": "dnd5e.ui.magia.cone",
        "shape": "cone",
        "style": {
          "stroke": "rgba(168, 85, 247, 0.96)",
          "fill": "rgba(168, 85, 247, 0.16)",
          "strokeWidth": 2
        }
      },
      {
        "id": "dnd5e-spell-line",
        "labelKey": "dnd5e.ui.magia.linha",
        "shape": "line",
        "style": {
          "stroke": "rgba(96, 165, 250, 0.96)",
          "fill": "rgba(96, 165, 250, 0.16)",
          "strokeWidth": 3
        }
      },
      {
        "id": "dnd5e-spell-cube",
        "labelKey": "dnd5e.ui.magia.cubo.quadrado",
        "shape": "square",
        "style": {
          "stroke": "rgba(45, 212, 191, 0.96)",
          "fill": "rgba(45, 212, 191, 0.16)",
          "strokeWidth": 2
        }
      },
      {
        "id": "dnd5e-aura",
        "labelKey": "dnd5e.ui.aura",
        "shape": "circle",
        "style": {
          "stroke": "rgba(250, 204, 21, 0.96)",
          "fill": "rgba(250, 204, 21, 0.14)",
          "strokeWidth": 2,
          "strokeDasharray": "6 5"
        }
      },
      {
        "id": "dnd5e-difficult-terrain",
        "labelKey": "dnd5e.ui.terreno.dificil",
        "shape": "square",
        "style": {
          "stroke": "rgba(34, 197, 94, 0.96)",
          "fill": "rgba(34, 197, 94, 0.14)",
          "strokeWidth": 2,
          "strokeDasharray": "8 6"
        }
      },
      {
        "id": "dnd5e-hazard",
        "labelKey": "dnd5e.ui.perigo.efeito.ativo",
        "shape": "square",
        "style": {
          "stroke": "rgba(248, 113, 113, 0.96)",
          "fill": "rgba(248, 113, 113, 0.16)",
          "strokeWidth": 2,
          "strokeDasharray": "8 6"
        }
      }
    ],
    "rules": {
      "formulas": "rules/formulas.gw.json",
      "derived": "rules/derived.gw.json",
      "actions": "rules/actions.gw.json",
      "validation": "rules/validation.gw.json",
      "conditions": "rules/conditions.gw.json",
      "combat": "rules/combat.gw.json"
    },
    "mappings": {
      "tokens": "mappings/token.gw.json",
      "chatCards": "mappings/chat-cards.gw.json",
      "rollToast": "mappings/roll-toast.gw.json"
    },
    "contentPacks": [
      {
        "id": "dnd5e-weapons",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.armas",
        "path": "content/items.weapons.gwpack.json"
      },
      {
        "id": "dnd5e-armor",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.armaduras",
        "path": "content/items.armor.gwpack.json"
      },
      {
        "id": "dnd5e-equipment",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.equipamentos",
        "path": "content/items.equipment.gwpack.json"
      },
      {
        "id": "dnd5e-consumables",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.consumiveis",
        "path": "content/items.consumables.gwpack.json"
      },
      {
        "id": "dnd5e-spells",
        "type": "spell_pack",
        "labelKey": "dnd5e.ui.magias",
        "path": "content/spells.gwpack.json"
      },
      {
        "id": "dnd5e-feats",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.talentos",
        "path": "content/items.feats.gwpack.json"
      },
      {
        "id": "dnd5e-features",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.caracteristicas",
        "path": "content/items.features.gwpack.json"
      },
      {
        "id": "dnd5e-monster-actions",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.acoes.de.monstro",
        "path": "content/items.monster-actions.gwpack.json"
      },
      {
        "id": "dnd5e-races",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.racas",
        "path": "content/items.races.gwpack.json"
      },
      {
        "id": "dnd5e-backgrounds",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.antecedentes",
        "path": "content/items.backgrounds.gwpack.json"
      },
      {
        "id": "dnd5e-classes",
        "type": "item_pack",
        "labelKey": "dnd5e.ui.classes",
        "path": "content/items.classes.gwpack.json"
      },
      {
        "id": "dnd5e-monsters",
        "type": "actor_pack",
        "labelKey": "dnd5e.ui.monstros",
        "path": "content/actors.monsters.gwpack.json"
      },
      {
        "id": "dnd5e-conditions",
        "type": "condition_pack",
        "labelKey": "dnd5e.ui.efeitos.and.condicoes",
        "path": "content/conditions.gwpack.json"
      }
    ],
    "locales": {
      "pt-BR": "locales/pt-BR.json",
      "en": "locales/en.json"
    }
  }
}
