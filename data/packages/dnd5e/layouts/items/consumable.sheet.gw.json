{
  "kind": "itemSheet",
  "system": "dnd5e",
  "id": "dnd5e-consumable",
  "title": {
    "bind": "core.name"
  },
  "body": {
    "type": "section",
    "children": [
      {
        "type": "row",
        "children": [
          {
            "type": "textField",
            "path": "core.name",
            "labelKey": "dnd5e.ui.nome"
          },
          {
            "type": "selectField",
            "path": "sheet.subtype",
            "options": [
              {
                "value": "potion",
                "labelKey": "dnd5e.ui.pocao"
              },
              {
                "value": "scroll",
                "labelKey": "dnd5e.ui.pergaminho"
              },
              {
                "value": "ammo",
                "labelKey": "dnd5e.ui.municao"
              },
              {
                "value": "food",
                "labelKey": "dnd5e.ui.comida.bebida"
              },
              {
                "value": "other",
                "labelKey": "dnd5e.ui.outro"
              }
            ],
            "labelKey": "dnd5e.ui.tipo"
          }
        ]
      },
      {
        "type": "row",
        "children": [
          {
            "type": "numberField",
            "path": "sheet.quantity",
            "labelKey": "dnd5e.ui.quantidade"
          },
          {
            "type": "numberField",
            "path": "sheet.uses",
            "labelKey": "dnd5e.ui.usos"
          },
          {
            "type": "numberField",
            "path": "sheet.weight",
            "labelKey": "dnd5e.ui.peso"
          },
          {
            "type": "textField",
            "path": "sheet.cost",
            "labelKey": "dnd5e.ui.custo"
          }
        ]
      },
      {
        "type": "textArea",
        "path": "sheet.description",
        "labelKey": "dnd5e.ui.efeito.descricao"
      }
    ],
    "labelKey": "dnd5e.ui.consumivel"
  }
}
